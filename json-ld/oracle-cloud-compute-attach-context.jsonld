{
  "@context": {
    "@version": 1.1,
    "oci": "https://docs.oracle.com/en-us/iaas/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "AttachVolumeDetails": "oci:AttachVolumeDetails",
    "displayName": {
      "@id": "oci:displayName",
      "@type": "xsd:string"
    },
    "instanceId": {
      "@id": "oci:instanceId",
      "@type": "xsd:string"
    },
    "isReadOnly": {
      "@id": "oci:isReadOnly",
      "@type": "xsd:boolean"
    },
    "type": {
      "@id": "oci:type",
      "@type": "xsd:string"
    },
    "volumeId": {
      "@id": "oci:volumeId",
      "@type": "xsd:string"
    }
  }
}