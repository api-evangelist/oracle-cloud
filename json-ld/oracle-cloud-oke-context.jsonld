{
  "@context": {
    "@version": 1.1,
    "oci": "https://docs.oracle.com/en-us/iaas/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Cluster": "oci:Cluster",
    "compartmentId": {
      "@id": "oci:compartmentId",
      "@type": "xsd:string"
    },
    "endpoints": {
      "@id": "oci:endpoints"
    },
    "id": {
      "@id": "oci:id",
      "@type": "xsd:string"
    },
    "kubernetesVersion": {
      "@id": "oci:kubernetesVersion",
      "@type": "xsd:string"
    },
    "lifecycleState": {
      "@id": "oci:lifecycleState",
      "@type": "xsd:string"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "timeCreated": {
      "@id": "schema:dateCreated",
      "@type": "xsd:dateTime"
    },
    "vcnId": {
      "@id": "oci:vcnId",
      "@type": "xsd:string"
    }
  }
}