{
  "@context": {
    "@version": 1.1,
    "oci": "https://docs.oracle.com/en-us/iaas/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Metric": "oci:Metric",
    "Alarm": "oci:Alarm",
    "compartmentId": {
      "@id": "oci:compartmentId",
      "@type": "xsd:string"
    },
    "destinations": {
      "@id": "oci:destinations",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "dimensions": {
      "@id": "oci:dimensions"
    },
    "displayName": {
      "@id": "oci:displayName",
      "@type": "xsd:string"
    },
    "id": {
      "@id": "oci:id",
      "@type": "xsd:string"
    },
    "isEnabled": {
      "@id": "oci:isEnabled",
      "@type": "xsd:boolean"
    },
    "lifecycleState": {
      "@id": "oci:lifecycleState",
      "@type": "xsd:string"
    },
    "metricCompartmentId": {
      "@id": "oci:metricCompartmentId",
      "@type": "xsd:string"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "namespace": {
      "@id": "oci:namespace",
      "@type": "xsd:string"
    },
    "query": {
      "@id": "oci:query",
      "@type": "xsd:string"
    },
    "severity": {
      "@id": "oci:severity",
      "@type": "xsd:string"
    },
    "timeCreated": {
      "@id": "schema:dateCreated",
      "@type": "xsd:dateTime"
    }
  }
}