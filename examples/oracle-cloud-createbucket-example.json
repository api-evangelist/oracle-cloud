      "status": "200",
      "contentType": "application/json",
      "name": "CreateBucket200Example",
      "example": {
        "namespace": "my-namespace",
        "name": "my-bucket",
        "compartmentId": "ocid1.compartment.oc1..abcdefg123456",
        "createdBy": "example-value",
