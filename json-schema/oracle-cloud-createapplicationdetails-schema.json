{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CreateApplicationDetails",
  "title": "CreateApplicationDetails",
  "type": "object",
  "required": [
    "compartmentId",
    "displayName",
    "subnetIds"
  ],
  "properties": {
    "compartmentId": {
      "type": "string",
      "example": "ocid1.resource.oc1.iad.abcdefg123456"
    },
    "displayName": {
      "type": "string",
      "example": "my-resource"
    },
    "subnetIds": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "example": [
        "example-value"
      ]
    },
    "config": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "example": {
        "key1": "value1"
      }
    }
  }
}