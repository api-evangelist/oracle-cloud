{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Policy",
  "title": "Policy",
  "type": "object",
  "description": "An IAM policy with authorization statements.",
  "properties": {
    "id": {
      "type": "string",
      "example": "ocid1.resource.oc1.iad.abcdefg123456"
    },
    "compartmentId": {
      "type": "string",
      "example": "ocid1.resource.oc1.iad.abcdefg123456"
    },
    "name": {
      "type": "string",
      "example": "AllowAdmins"
    },
    "description": {
      "type": "string",
      "example": "example-value"
    },
    "statements": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "example": [
        "Allow group Administrators to manage all-resources in tenancy"
      ]
    },
    "lifecycleState": {
      "type": "string",
      "enum": [
        "CREATING",
        "ACTIVE",
        "INACTIVE",
        "DELETING",
        "DELETED"
      ],
      "example": "CREATING"
    },
    "timeCreated": {
      "type": "string",
      "format": "date-time",
      "example": "2026-04-18T10:30:00Z"
    }
  }
}